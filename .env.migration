
# 🔗 قاعدة البيانات القديمة (Supabase)
# استبدل هذه القيم بمعلومات Supabase الخاصة بك
SUPABASE_DATABASE_URL=postgresql://postgres:YOUR_SUPABASE_PASSWORD@YOUR_SUPABASE_HOST:5432/postgres?sslmode=require

# 🔗 قاعدة البيانات الجديدة (السيرفر الخارجي)
# DATABASE_URL موجود بالفعل في .env الأساسي
# DATABASE_URL=postgresql://app2data:Ay**--772283228@93.127.142.144:5432/app2data?sslmode=require

# 📊 إعدادات الترحيل
MIGRATION_BATCH_SIZE=100
MIGRATION_DELAY_MS=1000
MAX_RETRIES=3
