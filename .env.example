# 🌐 Server Configuration
PORT=5000
NODE_ENV=development
HEALTH_CHECK_PORT=5000
HEALTH_CHECK_URL=http://localhost:5000/api/health
LOG_LEVEL=debug
DOMAIN=localhost:5000
ENABLE_QUICK_LOGIN=false

# 🗄️ Database Configuration
DATABASE_URL=postgresql://user:password@host:5432/database
OLD_DB_URL=postgresql://user:password@legacy-host:5432/database

# 🔐 Authentication & Security
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# 📧 Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password_here

# 🌊 Supabase Configuration (Optional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_DATABASE_URL=postgresql://postgres:password@host:5432/postgres
SUPABASE_DATABASE_PASSWORD=your_password_here

# 🌐 Domain Configuration & API Connection
API_BASE_URL=https://app2.binarjoinanalytic.info
REPLIT_DOMAINS=your-replit-domain.repl.co
REPLIT_DEV_DOMAIN=your-dev-domain.repl.dev
CUSTOM_DOMAIN=app2.binarjoinanalytic.info

# 📱 Frontend Environment Variables (للتطبيق الخارجي)
# استخدم VITE_API_BASE_URL عند البناء من خلال السرفر الخارجي
# مثال: npm run build -- VITE_API_BASE_URL=https://app2.binarjoinanalytic.info
VITE_API_BASE_URL=https://app2.binarjoinanalytic.info

# 🔧 Replit Platform Metadata (Auto-populated by Replit)
REPL_ID=your-repl-id
REPL_OWNER=your-username
REPL_SLUG=your-repl-slug

# 🚀 Deployment Platform Configuration (Optional - for specific platforms)
# AWS Configuration
AWS_REGION=us-east-1
AWS_LAMBDA_FUNCTION_NAME=construction-manager

# Netlify Configuration
NETLIFY_DEPLOY_ID=your-deploy-id
NETLIFY_REGION=us-east-1

# Vercel Configuration
VERCEL=0

# CI/CD Configuration
BUILD_ID=local-build
