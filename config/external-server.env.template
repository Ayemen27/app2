# =====================================================
# متغيرات البيئة للخادم الخارجي
# قالب — استبدل <PLACEHOLDER> بالقيم الفعلية
# =====================================================

# ========== قاعدة البيانات المركزية ==========
DATABASE_URL_CENTRAL=postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>
DATABASE_URL_SUPABASE=postgresql://<SUPABASE_USER>:<SUPABASE_PASSWORD>@<SUPABASE_HOST>:5432/<SUPABASE_DB>

# ========== إعدادات PostgreSQL ==========
PGHOST=<DB_HOST>
PGPORT=5432
PGDATABASE=<DB_NAME>
PGUSER=<DB_USER>
PGPASSWORD=<DB_PASSWORD>
DB_NAME=<DB_NAME>
DB_USER=<DB_USER>

# ========== إعدادات الخادم ==========
NODE_ENV=production
PORT=6000
PLATFORM=web
HEALTH_CHECK_PORT=6000
HEALTH_CHECK_URL=http://localhost:6000/api/health
HEALTH_CHECK_INTERVAL=30000

# ========== الدومين ==========
DOMAIN=https://<YOUR_DOMAIN>
PRODUCTION_DOMAIN=https://<YOUR_DOMAIN>
PRODUCTION_URL=https://<YOUR_DOMAIN>
API_BASE_URL=<YOUR_DOMAIN>/api
VITE_API_BASE_URL=<YOUR_DOMAIN>
VITE_PRODUCTION_DOMAIN=https://<YOUR_DOMAIN>
VITE_PRODUCTION_HOSTS=<YOUR_DOMAIN>,<ROOT_DOMAIN>,www.<ROOT_DOMAIN>
ALLOWED_DOMAIN_SUFFIXES=<ROOT_DOMAIN>

# ========== SSH ==========
SSH_HOST=<SERVER_IP>
SSH_USER=<SSH_USERNAME>
SSH_PORT=22

# ========== نظام النسخ الاحتياطي ==========
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=6
EMERGENCY_BACKUP_PATH=./backups/emergency-latest.sql.gz

# ========== Circuit Breaker ==========
CIRCUIT_BREAKER_THRESHOLD=50
CIRCUIT_BREAKER_TIMEOUT=5000
CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# ========== مفاتيح التشفير (يجب تعيينها) ==========
# JWT_ACCESS_SECRET=<your-jwt-access-secret>
# JWT_REFRESH_SECRET=<your-jwt-refresh-secret>
# ENCRYPTION_KEY=<your-64-char-hex-key>
# ENCRYPTION_SALT=<your-32-char-hex-salt>
# SESSION_SECRET=<your-session-secret>

# ========== خدمات خارجية (اختياري) ==========
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
# TELEGRAM_CHAT_ID=<your-chat-id>
# OPENAI_API_KEY=<your-openai-key>
